<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Snablr Scan Report</title>
  <style>
    :root {
      --bg: #edf3f7;
      --panel: #ffffff;
      --panel-alt: #f7fafc;
      --text: #12263a;
      --muted: #60758c;
      --line: #d8e4ee;
      --shadow: 0 10px 30px rgba(16, 35, 62, 0.08);
      --low: #2563eb;
      --medium: #d97706;
      --high: #dc2626;
      --critical: #8f1239;
      --low-bg: #e8f0ff;
      --medium-bg: #fff2df;
      --high-bg: #fde9ea;
      --critical-bg: #fae8ef;
      --ok-bg: #e7f7ef;
      --ok: #15803d;
      --ad-bg: #ecfdf5;
      --ad: #047857;
      --dfs-bg: #eef2ff;
      --dfs: #4338ca;
      --ldap-bg: #eff6ff;
      --ldap: #1d4ed8;
      --cli-bg: #eefdf4;
      --cli: #15803d;
      --file-bg: #fff7ed;
      --file: #c2410c;
      --generic-bg: #eef2f7;
      --generic: #51637d;
      --prio-low-bg: #eef2f7;
      --prio-low: #51637d;
      --prio-medium-bg: #fff6db;
      --prio-medium: #b45309;
      --prio-high-bg: #ffe7dd;
      --prio-high: #c2410c;
      --prio-critical-bg: #ffe3ea;
      --prio-critical: #be123c;
      --diff-new-bg: #dcfce7;
      --diff-new: #166534;
      --diff-changed-bg: #fef3c7;
      --diff-changed: #a16207;
      --diff-removed-bg: #fee2e2;
      --diff-removed: #b91c1c;
      --diff-unchanged-bg: #e2e8f0;
      --diff-unchanged: #475569;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(104, 145, 180, 0.12), transparent 25%),
        linear-gradient(180deg, #f4f8fb 0%, var(--bg) 24%, #f7fafc 100%);
      font: 15px/1.5 "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    }
    main {
      max-width: 1500px;
      margin: 0 auto;
      padding: 28px 20px 56px;
    }
    h1, h2, h3, p { margin: 0; }
    .hero {
      background: rgba(255,255,255,0.86);
      border: 1px solid var(--line);
      border-radius: 22px;
      box-shadow: var(--shadow);
      padding: 24px;
      margin-bottom: 22px;
      backdrop-filter: blur(8px);
    }
    .hero-top {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }
    .hero h1 {
      font-size: 2.1rem;
      letter-spacing: -0.03em;
      margin-bottom: 6px;
    }
    .report-kicker {
      display: inline-block;
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 8px;
    }
    .subtitle {
      color: var(--muted);
      max-width: 780px;
    }
    .hero-meta {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 14px;
    }
    .meta-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #f8fbff;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 12px;
      color: var(--muted);
      font-size: 0.86rem;
      font-weight: 600;
    }
    .meta-pill strong {
      color: var(--text);
      font-weight: 700;
    }
    .hero-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .hero-actions a {
      color: var(--text);
      text-decoration: none;
      font-weight: 600;
      background: #f7fafc;
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 12px;
    }
    .toolbar {
      display: grid;
      grid-template-columns: minmax(260px, 1.2fr) auto;
      gap: 12px;
      align-items: center;
    }
    .filter-grid {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      margin-top: 14px;
    }
    .filter-control {
      display: grid;
      gap: 6px;
    }
    .filter-control label,
    .toggle-label {
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .filter-select,
    .filter-text {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fbfdff;
      color: var(--text);
      font: inherit;
    }
    .toggle-grid {
      display: flex;
      gap: 10px 18px;
      flex-wrap: wrap;
      margin-top: 14px;
      align-items: center;
    }
    .toggle-option {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      color: var(--text);
      font-size: 0.92rem;
    }
    .filter-actions {
      display: flex;
      gap: 12px;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 14px;
    }
    .filter-status {
      color: var(--muted);
      font-size: 0.9rem;
    }
    .filter-reset {
      border: 1px solid var(--line);
      background: #fff;
      color: var(--text);
      border-radius: 999px;
      padding: 8px 12px;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
    }
    .filter-wrap {
      position: relative;
    }
    .filter-input {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fbfdff;
      color: var(--text);
      font: inherit;
    }
    .filter-help {
      color: var(--muted);
      font-size: 0.88rem;
      text-align: right;
    }
    .summary-grid,
    .severity-grid,
    .category-grid,
    .host-grid {
      display: grid;
      gap: 14px;
      margin-bottom: 22px;
    }
    .summary-grid { grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); }
    .severity-grid { grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); }
    .category-grid { grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }
    .host-grid { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .card {
      background: rgba(255,255,255,0.92);
      border: 1px solid var(--line);
      border-radius: 18px;
      box-shadow: var(--shadow);
      padding: 16px 18px;
    }
    .card-label {
      display: block;
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 8px;
    }
    .card-value {
      font-size: 1.55rem;
      font-weight: 700;
      letter-spacing: -0.03em;
    }
    .card-meta {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.9rem;
    }
    .section-head {
      display: flex;
      gap: 12px;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      margin: 28px 0 12px;
    }
    .section-head h2 {
      font-size: 1.25rem;
      letter-spacing: -0.02em;
    }
    .section-note {
      color: var(--muted);
      font-size: 0.92rem;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 0.76rem;
      font-weight: 700;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      white-space: nowrap;
      border: 1px solid transparent;
    }
    .badge.sev-low { background: var(--low-bg); color: var(--low); }
    .badge.sev-medium { background: var(--medium-bg); color: var(--medium); }
    .badge.sev-high { background: var(--high-bg); color: var(--high); }
    .badge.sev-critical { background: var(--critical-bg); color: var(--critical); }
    .badge.sev-unknown { background: var(--prio-low-bg); color: var(--prio-low); }
    .badge.source-ldap { background: var(--ldap-bg); color: var(--ldap); }
    .badge.source-dfs { background: var(--dfs-bg); color: var(--dfs); }
    .badge.source-cli { background: var(--cli-bg); color: var(--cli); }
    .badge.source-file { background: var(--file-bg); color: var(--file); }
    .badge.source-generic { background: var(--generic-bg); color: var(--generic); }
    .badge.ad-share { background: var(--ad-bg); color: var(--ad); }
    .badge.prio-low { background: var(--prio-low-bg); color: var(--prio-low); }
    .badge.prio-medium { background: var(--prio-medium-bg); color: var(--prio-medium); }
    .badge.prio-high { background: var(--prio-high-bg); color: var(--prio-high); }
    .badge.prio-critical { background: var(--prio-critical-bg); color: var(--prio-critical); }
    .badge.conf-low { background: #e0f2fe; color: #0369a1; }
    .badge.conf-medium { background: #fef3c7; color: #b45309; }
    .badge.conf-high { background: #dcfce7; color: #15803d; }
    .badge.conf-unknown { background: var(--prio-low-bg); color: var(--prio-low); }
    .badge.good { background: var(--ok-bg); color: var(--ok); }
    .badge.signal-content { background: #e0f2fe; color: #0f766e; }
    .badge.signal-validated { background: #dcfce7; color: #166534; }
    .badge.signal-filename { background: #fff7ed; color: #c2410c; }
    .badge.signal-extension { background: #f3e8ff; color: #7c3aed; }
    .badge.signal-path { background: #ecfccb; color: #4d7c0f; }
    .badge.signal-directory { background: #ecfccb; color: #365314; }
    .badge.signal-generic { background: var(--generic-bg); color: var(--generic); }
    .badge.diff-new { background: var(--diff-new-bg); color: var(--diff-new); }
    .badge.diff-changed { background: var(--diff-changed-bg); color: var(--diff-changed); }
    .badge.diff-removed { background: var(--diff-removed-bg); color: var(--diff-removed); }
    .badge.diff-unchanged { background: var(--diff-unchanged-bg); color: var(--diff-unchanged); }
    .badge.diff-unknown { background: var(--generic-bg); color: var(--generic); }
    .badge.triage-actionable { background: #dcfce7; color: #166534; }
    .badge.triage-config { background: #e2e8f0; color: #475569; }
    .badge.triage-weak { background: #fef3c7; color: #92400e; }
    .badge.triage-unknown { background: var(--generic-bg); color: var(--generic); }
    .category-card .card-meta {
      line-height: 1.55;
    }
    .host-card .card-value {
      font-size: 1.2rem;
      line-height: 1.2;
      word-break: break-word;
    }
    .nav-chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .nav-chips a {
      text-decoration: none;
      color: var(--text);
      background: rgba(255,255,255,0.92);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 0.88rem;
      font-weight: 600;
      box-shadow: var(--shadow);
    }
	    details.group {
	      background: rgba(255,255,255,0.94);
	      border: 1px solid var(--line);
	      border-radius: 18px;
	      box-shadow: var(--shadow);
	      margin-bottom: 18px;
	      overflow: visible;
	    }
    details.group[open] {
      background: #fff;
    }
    summary.group-summary {
      list-style: none;
      cursor: pointer;
      padding: 18px 20px;
      background: linear-gradient(180deg, #f8fbff, #ffffff);
      border-bottom: 1px solid var(--line);
    }
    summary.group-summary::-webkit-details-marker { display: none; }
    .group-top {
      display: flex;
      gap: 12px;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .group-title {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }
    .group-title h3 {
      font-size: 1.15rem;
      letter-spacing: -0.02em;
    }
    .group-stats {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 0.9rem;
    }
    .group-guidance {
      color: #183153;
      max-width: 1000px;
    }
	    .table-wrap {
	      overflow-x: auto;
	    }
    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
    }
    thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      background: #f8fbff;
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-align: left;
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
    }
    tbody tr:nth-child(odd) { background: rgba(255,255,255,0.98); }
    tbody tr:nth-child(even) { background: var(--panel-alt); }
    tbody tr.sev-high { background: linear-gradient(90deg, rgba(253,235,236,0.95), rgba(255,255,255,0.96)); }
    tbody tr.sev-critical { background: linear-gradient(90deg, rgba(250,232,239,0.96), rgba(255,255,255,0.97)); }
    tbody tr.status-new { box-shadow: inset 4px 0 0 var(--diff-new); }
    tbody tr.status-changed { box-shadow: inset 4px 0 0 var(--diff-changed); }
	    tbody tr.is-hidden,
	    .finding-card.is-hidden,
	    .group.is-hidden {
	      display: none;
	    }
    td {
      padding: 14px 16px;
      vertical-align: top;
      border-bottom: 1px solid var(--line);
      font-size: 0.93rem;
    }
    tbody tr:last-child td { border-bottom: 0; }
    .rule-name {
      display: block;
      margin-top: 5px;
      color: var(--muted);
      font-size: 0.88rem;
    }
    .badge-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 7px;
    }
	    .tooltip {
	      position: relative;
	      display: inline-block;
	      max-width: 100%;
    }
    .tooltip > span {
      display: inline-block;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      vertical-align: top;
    }
    .tooltip::after {
      content: attr(data-tip);
      position: absolute;
      left: 0;
      top: calc(100% + 8px);
      min-width: 220px;
      max-width: 520px;
      padding: 10px 12px;
      background: rgba(17, 24, 39, 0.96);
      color: #f8fafc;
      border-radius: 10px;
      font-size: 0.84rem;
      line-height: 1.45;
      white-space: pre-wrap;
      box-shadow: 0 14px 28px rgba(17, 24, 39, 0.22);
      opacity: 0;
      pointer-events: none;
      transform: translateY(4px);
      transition: opacity 0.16s ease, transform 0.16s ease;
      z-index: 20;
    }
    .tooltip:hover::after,
    .tooltip:focus-within::after {
      opacity: 1;
      transform: translateY(0);
    }
	    .path-text { max-width: 380px; }
	    .snippet-text,
	    .reason-text {
	      white-space: normal;
	      overflow-wrap: anywhere;
	      max-width: 420px;
	    }
	    .finding-list {
	      display: grid;
	      gap: 16px;
	      padding: 18px 20px 22px;
	    }
	    .finding-card {
	      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,250,252,0.96));
	      border: 1px solid var(--line);
	      border-radius: 16px;
	      padding: 18px;
	      box-shadow: 0 8px 20px rgba(16, 35, 62, 0.06);
	    }
	    .finding-card.sev-high {
	      border-color: #f4c7cf;
	      background: linear-gradient(180deg, rgba(254,242,242,0.96), rgba(255,255,255,0.98));
	    }
	    .finding-card.sev-critical {
	      border-color: #efbfd0;
	      background: linear-gradient(180deg, rgba(252,241,245,0.98), rgba(255,255,255,0.98));
	    }
	    .finding-card.status-new { box-shadow: inset 4px 0 0 var(--diff-new), 0 8px 20px rgba(16, 35, 62, 0.06); }
	    .finding-card.status-changed { box-shadow: inset 4px 0 0 var(--diff-changed), 0 8px 20px rgba(16, 35, 62, 0.06); }
	    .finding-card.status-removed { box-shadow: inset 4px 0 0 var(--diff-removed), 0 8px 20px rgba(16, 35, 62, 0.06); }
	    .finding-card.status-unchanged { box-shadow: inset 4px 0 0 var(--diff-unchanged), 0 8px 20px rgba(16, 35, 62, 0.06); }
	    .finding-card-header {
	      display: grid;
	      gap: 14px;
	      grid-template-columns: minmax(0, 1.3fr) minmax(260px, 0.9fr);
	      align-items: start;
	    }
	    .finding-title h4 {
	      font-size: 1.1rem;
	      line-height: 1.25;
	      margin: 10px 0 4px;
	    }
	    .finding-rule-id {
	      color: var(--muted);
	      font-size: 0.9rem;
	      font-weight: 600;
	      overflow-wrap: anywhere;
	    }
	    .finding-location {
	      display: grid;
	      gap: 10px;
	      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
	    }
	    .meta-chip {
	      background: rgba(248, 251, 255, 0.96);
	      border: 1px solid var(--line);
	      border-radius: 12px;
	      padding: 10px 12px;
	      min-width: 0;
	    }
	    .meta-chip strong {
	      display: block;
	      margin-top: 3px;
	      overflow-wrap: anywhere;
	    }
	    .meta-chip span {
	      color: var(--muted);
	      font-size: 0.78rem;
	      font-weight: 700;
	      text-transform: uppercase;
	      letter-spacing: 0.08em;
	    }
	    .finding-path {
	      margin-top: 14px;
	      padding: 12px 14px;
	      border-radius: 12px;
	      border: 1px solid var(--line);
	      background: rgba(248, 251, 255, 0.96);
	      color: #183153;
	      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
	      font-size: 0.88rem;
	      line-height: 1.5;
	      white-space: pre-wrap;
	      overflow-wrap: anywhere;
	      word-break: break-word;
	    }
	    .finding-body {
	      display: grid;
	      gap: 14px;
	      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
	      margin-top: 14px;
	    }
	    .finding-panel {
	      min-width: 0;
	      background: rgba(248, 251, 255, 0.92);
	      border: 1px solid var(--line);
	      border-radius: 14px;
	      padding: 14px;
	    }
	    .panel-title {
	      display: block;
	      margin-bottom: 10px;
	      font-size: 0.84rem;
	      font-weight: 700;
	      letter-spacing: 0.08em;
	      text-transform: uppercase;
	      color: var(--muted);
	    }
	    .detail-list {
	      display: grid;
	      gap: 10px;
	    }
	    .finding-text {
	      white-space: pre-wrap;
	      overflow-wrap: anywhere;
	      word-break: break-word;
	    }
	    .finding-note {
	      border-radius: 12px;
	      border: 1px solid #d7e7f4;
	      background: #f8fbff;
	      padding: 10px 12px;
	      color: #23405c;
	    }
	    .finding-note.heuristic {
	      border-color: #f6d8bf;
	      background: #fff7ed;
	      color: #9a3412;
	    }
	    .confidence-reasons,
	    .supporting-signal-list,
	    .raw-signal-list {
	      margin: 0;
	      padding-left: 18px;
	      display: grid;
	      gap: 8px;
	    }
	    .supporting-signal-list li,
	    .confidence-reasons li,
	    .raw-signal-list li {
	      overflow-wrap: anywhere;
	    }
	    .kv-grid {
	      display: grid;
	      gap: 10px;
	    }
	    .evidence-pair {
	      display: grid;
	      gap: 6px;
	    }
	    .evidence-label {
	      color: var(--muted);
	      font-size: 0.76rem;
	      font-weight: 700;
	      text-transform: uppercase;
	      letter-spacing: 0.08em;
	    }
	    .evidence-block {
	      margin: 0;
	      border-radius: 12px;
	      border: 1px solid var(--line);
	      background: #fff;
	      padding: 12px;
	      white-space: pre-wrap;
	      overflow-wrap: anywhere;
	      word-break: break-word;
	      font: 0.88rem/1.5 "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
	    }
	    .evidence-toggle {
	      margin-top: 14px;
	      border: 1px solid var(--line);
	      border-radius: 14px;
	      background: rgba(248, 251, 255, 0.92);
	      overflow: hidden;
	    }
	    .evidence-toggle summary {
	      cursor: pointer;
	      list-style: none;
	      padding: 12px 14px;
	      font-weight: 700;
	      color: #183153;
	    }
	    .evidence-toggle summary::-webkit-details-marker { display: none; }
	    .evidence-grid {
	      display: grid;
	      gap: 12px;
	      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	      padding: 0 14px 14px;
	    }
	    .evidence-section {
	      min-width: 0;
	      background: #fff;
	      border: 1px solid var(--line);
	      border-radius: 12px;
	      padding: 12px;
	    }
	    .meta-block {
	      display: grid;
	      gap: 8px;
    }
    .detail-stack {
      display: grid;
      gap: 10px;
    }
    .detail-panel {
      background: rgba(248, 251, 255, 0.9);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px 12px;
    }
    .detail-panel strong {
      display: block;
      margin-bottom: 4px;
    }
    .meta-line strong {
      display: inline-block;
      margin-right: 6px;
    }
    .muted { color: var(--muted); }
    .print-note {
      margin-top: 10px;
      color: var(--muted);
      font-size: 0.85rem;
    }
    @media print {
      body {
        background: #fff;
      }
      .hero-actions,
      .toolbar,
      .nav-chips {
        display: none !important;
      }
      .card,
      details.group {
        break-inside: avoid;
        box-shadow: none;
      }
      details.group[open] > summary.group-summary {
        border-bottom: 1px solid #ccc;
      }
      details.group:not([open]) > *:not(summary) {
        display: block;
      }
      .tooltip::after {
        display: none;
      }
      thead th {
        position: static;
      }
    }
	    @media (max-width: 900px) {
	      .toolbar {
	        grid-template-columns: 1fr;
	      }
	      .filter-help {
	        text-align: left;
	      }
	      .finding-list {
	        padding: 14px 14px 18px;
	      }
	      .finding-card {
	        padding: 14px;
	      }
	      .finding-card-header {
	        grid-template-columns: 1fr;
	      }
	      thead th,
	      td {
	        padding: 12px 10px;
	      }
	    }
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <div class="hero-top">
        <div>
          <span class="report-kicker">Snablr</span>
          <h1>Snablr Scan Report</h1>
          <p class="subtitle">Standalone defensive triage report for post-scan review. Use the filter to narrow findings quickly, then open the most relevant categories first.</p>
          <div class="hero-meta">
            <span class="meta-pill"><strong>Version</strong> {{ .Version }}</span>
            <span class="meta-pill"><strong>Started</strong> {{ formatScanTime .Summary.StartedAt }}</span>
            <span class="meta-pill"><strong>Completed</strong> {{ formatScanTime .Summary.EndedAt }}</span>
            <span class="meta-pill"><strong>Duration</strong> {{ formatDuration .Summary.StartedAt .Summary.EndedAt }}</span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="#severity-summary">Severity Summary</a>
          <a href="#category-summary">Category Summary</a>
          <a href="#host-summary">Host Summary</a>
          {{- if .Validation }}<a href="#validation-summary">Validation</a>{{- end }}
          <a href="#findings">Findings</a>
        </div>
      </div>
      <div class="toolbar">
        <div class="filter-wrap">
          <input id="quickFilter" class="filter-input" type="search" placeholder="Quick filter by host, share, rule, tag, category, path, source, SYSVOL, DFS..." aria-label="Quick filter findings">
        </div>
        <div class="filter-help">Filter runs locally in the report. Search is case-insensitive and checks the full row text.</div>
      </div>
      <div class="filter-grid">
        <div class="filter-control">
          <label for="severityFilter">Severity</label>
          <select id="severityFilter" class="filter-select">
            <option value="">All severities</option>
            <option value="critical">Critical</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
        </div>
        <div class="filter-control">
          <label for="categoryFilter">Category</label>
          <select id="categoryFilter" class="filter-select">
            <option value="">All categories</option>
            {{- range .FilterOptions.Categories }}
            <option value="{{ . }}">{{ . }}</option>
            {{- end }}
          </select>
        </div>
        <div class="filter-control">
          <label for="confidenceFilter">Confidence</label>
          <select id="confidenceFilter" class="filter-select">
            <option value="">All confidence levels</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
        </div>
        <div class="filter-control">
          <label for="sourceFilter">Source</label>
          <select id="sourceFilter" class="filter-select">
            <option value="">All sources</option>
            {{- range .FilterOptions.Sources }}
            <option value="{{ . }}">{{ . }}</option>
            {{- end }}
          </select>
        </div>
        <div class="filter-control">
          <label for="signalFilter">Signal Type</label>
          <select id="signalFilter" class="filter-select">
            <option value="">All signal types</option>
            {{- range .FilterOptions.Signals }}
            <option value="{{ . }}">{{ signalLabel . }}</option>
            {{- end }}
          </select>
        </div>
        <div class="filter-control">
          <label for="scopeFilter">Host / Share</label>
          <input id="scopeFilter" class="filter-text" type="search" list="scopeOptions" placeholder="Filter by host or share">
          <datalist id="scopeOptions">
            {{- range .FilterOptions.Scopes }}
            <option value="{{ . }}"></option>
            {{- end }}
          </datalist>
        </div>
      </div>
      <div class="toggle-grid">
        <label class="toggle-option"><input id="correlatedOnly" type="checkbox"> Show only correlated findings</label>
        <label class="toggle-option"><input id="hideConfigOnly" type="checkbox"> Hide config-only findings</label>
        <label class="toggle-option"><input id="hideLowConfidence" type="checkbox"> Hide medium or lower confidence</label>
        <label class="toggle-option"><input id="hideNonActionable" type="checkbox"> Hide findings without actionable evidence</label>
      </div>
      <div class="filter-actions">
        <button id="resetFilters" class="filter-reset" type="button">Reset Filters</button>
        <div id="filterStatus" class="filter-status">Showing all findings</div>
      </div>
      <div class="print-note">Printable/exportable: collapse sections to focus before printing, or open all to export a fuller review pack.</div>
    </section>

    <section class="summary-grid">
      <article class="card">
        <span class="card-label">Hosts Scanned</span>
        <span class="card-value">{{ .Summary.HostsScanned }}</span>
        <div class="card-meta">Targets loaded {{ .Metrics.Counters.TargetsLoaded }} · reachable {{ .Metrics.Counters.TargetsReachable }}</div>
      </article>
      <article class="card">
        <span class="card-label">Shares Scanned</span>
        <span class="card-value">{{ .Summary.SharesScanned }}</span>
        <div class="card-meta">Enumerated {{ .Metrics.Counters.SharesEnumerated }}</div>
      </article>
      <article class="card">
        <span class="card-label">Files Scanned</span>
        <span class="card-value">{{ .Summary.FilesScanned }}</span>
        <div class="card-meta">Files read {{ .Metrics.Counters.FilesRead }}</div>
      </article>
      <article class="card">
        <span class="card-label">Matches Found</span>
        <span class="card-value">{{ .Summary.MatchesFound }}</span>
      </article>
      <article class="card">
        <span class="card-label">Skipped Files</span>
        <span class="card-value">{{ .Summary.SkippedFiles }}</span>
      </article>
      <article class="card">
        <span class="card-label">Read Errors</span>
        <span class="card-value">{{ .Summary.ReadErrors }}</span>
      </article>
      <article class="card">
        <span class="card-label">Scan Duration</span>
        <span class="card-value">{{ formatDuration .Summary.StartedAt .Summary.EndedAt }}</span>
        <div class="card-meta">Start {{ formatScanTime .Summary.StartedAt }} · End {{ formatScanTime .Summary.EndedAt }}</div>
      </article>
    </section>

    {{- if .Validation }}
    <section id="validation-summary">
      <div class="section-head">
        <h2>Seeded Validation</h2>
        <span class="section-note">Expected seeded outcomes compared to the findings surfaced in this run.</span>
      </div>
      <div class="summary-grid">
        <article class="card">
          <span class="card-label">Expected</span>
          <span class="card-value">{{ .Validation.ExpectedItems }}</span>
        </article>
        <article class="card">
          <span class="card-label">Detected</span>
          <span class="card-value">{{ .Validation.FoundItems }}</span>
        </article>
        <article class="card">
          <span class="card-label">Missed</span>
          <span class="card-value">{{ .Validation.MissedItems }}</span>
        </article>
        <article class="card">
          <span class="card-label">Unexpected</span>
          <span class="card-value">{{ .Validation.UnexpectedFindings }}</span>
        </article>
        <article class="card">
          <span class="card-label">Config Suppressed</span>
          <span class="card-value">{{ .Validation.SuppressedConfigOnly }}</span>
        </article>
        <article class="card">
          <span class="card-label">Actionable Promoted</span>
          <span class="card-value">{{ .Validation.PromotedActionable }}</span>
        </article>
        <article class="card">
          <span class="card-label">Correlated Promoted</span>
          <span class="card-value">{{ .Validation.PromotedCorrelated }}</span>
        </article>
      </div>

      {{- if .Validation.ClassCoverage }}
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Expected Class</th>
              <th>Planted</th>
              <th>Detected</th>
              <th>Missed</th>
              <th>Suppressed</th>
              <th>Downgraded</th>
              <th>Promoted</th>
              <th>Mismatched</th>
            </tr>
          </thead>
          <tbody>
            {{- range .Validation.ClassCoverage }}
            <tr>
              <td><strong>{{ .Label }}</strong></td>
              <td>{{ .Planted }}</td>
              <td>{{ .Detected }}</td>
              <td>{{ .Missed }}</td>
              <td>{{ .Suppressed }}</td>
              <td>{{ .Downgraded }}</td>
              <td>{{ .Promoted }}</td>
              <td>{{ .Mismatched }}</td>
            </tr>
            {{- end }}
          </tbody>
        </table>
      </div>
      {{- end }}

      <div class="severity-grid">
        <article class="card">
          <span class="card-label">Missed Expected Items</span>
          <div class="card-meta">
            {{- if .Validation.MissedExpected }}
            {{- range .Validation.MissedExpected }}
            <div><strong>{{ .Label }}</strong> · {{ valueOrDash .Host }}/{{ valueOrDash .Share }}/{{ .Path }}</div>
            {{- end }}
            {{- else }}
            <div>None</div>
            {{- end }}
          </div>
        </article>
        <article class="card">
          <span class="card-label">Over-Promoted Items</span>
          <div class="card-meta">
            {{- if .Validation.OverPromoted }}
            {{- range .Validation.OverPromoted }}
            <div><strong>{{ .Label }}</strong> · {{ valueOrDash .Host }}/{{ valueOrDash .Share }}/{{ .Path }} · observed {{ valueOrDash .ObservedTriageClass }} / {{ valueOrDash .ObservedConfidence }}</div>
            {{- end }}
            {{- else }}
            <div>None</div>
            {{- end }}
          </div>
        </article>
      </div>
    </section>
    {{- end }}

    {{- if .DiffSummary }}
    <section id="diff-summary">
      <div class="section-head">
        <h2>Baseline Diff</h2>
        <span class="section-note">Change tracking against the supplied baseline JSON report.</span>
      </div>
      <div class="severity-grid">
        <article class="card">
          <span class="card-label">New Findings</span>
          <span class="card-value">{{ .DiffSummary.New }}</span>
          <div class="card-meta"><span class="badge diff-new">new</span></div>
        </article>
        <article class="card">
          <span class="card-label">Changed Findings</span>
          <span class="card-value">{{ .DiffSummary.Changed }}</span>
          <div class="card-meta"><span class="badge diff-changed">changed</span></div>
        </article>
        <article class="card">
          <span class="card-label">Removed Findings</span>
          <span class="card-value">{{ .DiffSummary.Removed }}</span>
          <div class="card-meta"><span class="badge diff-removed">removed</span></div>
        </article>
        <article class="card">
          <span class="card-label">Unchanged Findings</span>
          <span class="card-value">{{ .DiffSummary.Unchanged }}</span>
          <div class="card-meta"><span class="badge diff-unchanged">unchanged</span></div>
        </article>
      </div>
    </section>
    {{- end }}

    {{- if .ChangedFindings }}
    <section id="changed-findings">
      <div class="section-head">
        <h2>Changed Since Baseline</h2>
        <span class="section-note">Same finding identity, but important metadata changed between runs.</span>
      </div>
      <details class="group">
        <summary class="group-summary">
          <div class="group-top">
            <div class="group-title">
              <h3>Changed Findings</h3>
              <span class="badge diff-changed">{{ len .ChangedFindings }} changed</span>
            </div>
          </div>
        </summary>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rule</th>
                <th>Host / Share</th>
                <th>File Path</th>
                <th>Changed Fields</th>
              </tr>
            </thead>
            <tbody>
              {{- range .ChangedFindings }}
              <tr>
                <td>
                  <strong>{{ .Current.RuleID }}</strong>
                  <span class="rule-name">{{ .Current.RuleName }}</span>
                </td>
                <td>
                  <div><strong>{{ valueOrDash .Current.Host }}</strong></div>
                  <div class="muted">{{ valueOrDash .Current.Share }}</div>
                </td>
                <td>
                  <span class="tooltip path-text" data-tip="{{ uncPath .Current }}">
                    <span>{{ truncatePath (uncPath .Current) }}</span>
                  </span>
                </td>
                <td>
                  <div class="badge-row" style="margin-top:0;">
                    {{- range .ChangedFields }}<span class="badge diff-changed">{{ . }}</span>{{ end -}}
                  </div>
                </td>
              </tr>
              {{- end }}
            </tbody>
          </table>
        </div>
      </details>
    </section>
    {{- end }}

    {{- if .RemovedFindings }}
    <section id="removed-findings">
      <div class="section-head">
        <h2>Removed Since Baseline</h2>
        <span class="section-note">Present in the baseline, not present in this run.</span>
      </div>
      <details class="group">
        <summary class="group-summary">
          <div class="group-top">
            <div class="group-title">
              <h3>Removed Findings</h3>
              <span class="badge diff-removed">{{ len .RemovedFindings }} removed</span>
            </div>
          </div>
        </summary>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Rule</th>
                <th>Host / Share</th>
                <th>File Path</th>
                <th>Match</th>
              </tr>
            </thead>
            <tbody>
              {{- range .RemovedFindings }}
              <tr>
                <td>
                  <strong>{{ .RuleID }}</strong>
                  <span class="rule-name">{{ .RuleName }}</span>
                </td>
                <td>
                  <div><strong>{{ valueOrDash .Host }}</strong></div>
                  <div class="muted">{{ valueOrDash .Share }}</div>
                </td>
                <td>
                  <span class="tooltip path-text" data-tip="{{ uncPath . }}">
                    <span>{{ truncatePath (uncPath .) }}</span>
                  </span>
                </td>
                <td>
                  {{- if .Match }}
                  <span class="tooltip snippet-text" data-tip="{{ .Match }}">
                    <span>{{ .Match }}</span>
                  </span>
                  {{- else }}
                  <span class="muted">-</span>
                  {{- end }}
                </td>
              </tr>
              {{- end }}
            </tbody>
          </table>
        </div>
      </details>
    </section>
    {{- end }}

    <section id="phase-timings">
      <div class="section-head">
        <h2>Phase Timings</h2>
        <span class="section-note">Lightweight timing by major scan phase.</span>
      </div>
      <div class="severity-grid">
        {{- range .Metrics.Phases }}
        <article class="card">
          <span class="card-label">{{ .Name }}</span>
          <span class="card-value">{{ .DurationMS }} ms</span>
        </article>
        {{- end }}
      </div>
    </section>

    <section id="severity-summary">
      <div class="section-head">
        <h2>Severity Summary</h2>
        <span class="section-note">Use this first to decide which sections to open.</span>
      </div>
      <div class="severity-grid">
        {{- range .SeveritySummaries }}
        <article class="card">
          <span class="card-label">{{ .Severity }}</span>
          <span class="card-value">{{ .Count }}</span>
          <div class="card-meta"><span class="badge {{ severityClass .Severity }}">{{ .Severity }}</span></div>
        </article>
        {{- end }}
      </div>
    </section>

    <section id="category-summary">
      <div class="section-head">
        <h2>Category Summary</h2>
        <span class="section-note">Each category links to a collapsible findings section below.</span>
      </div>
      <div class="nav-chips">
        {{- range .CategorySummaries }}
        <a href="#cat-{{ slug .Category }}">{{ .Category }} ({{ .Findings }})</a>
        {{- end }}
      </div>
      <div class="category-grid" style="margin-top: 14px;">
        {{- range .CategorySummaries }}
        <article class="card category-card">
          <span class="card-label">{{ .Category }}</span>
          <span class="card-value">{{ .Findings }}</span>
          <div class="card-meta">
            <div>Highest severity: <span class="badge {{ severityClass .HighestSeverity }}">{{ .HighestSeverity }}</span></div>
            <div>Critical {{ .Critical }} · High {{ .High }} · Medium {{ .Medium }} · Low {{ .Low }}</div>
            <div>{{ .RemediationGuidance }}</div>
          </div>
        </article>
        {{- end }}
      </div>
    </section>

    <section id="host-summary">
      <div class="section-head">
        <h2>Host Summary</h2>
        <span class="section-note">Highest-signal hosts based on current findings volume and severity.</span>
      </div>
      <div class="host-grid">
        {{- range .HostSummaries }}
        <article class="card host-card">
          <span class="card-label">Host</span>
          <span class="card-value">{{ .Host }}</span>
          <div class="card-meta">
            <div>{{ .Findings }} findings · {{ .Shares }} shares · {{ .Categories }} categories</div>
            <div style="margin-top:8px;"><span class="badge {{ severityClass .HighestSeverity }}">{{ .HighestSeverity }}</span></div>
            <div class="badge-row">
              {{- if .FromLDAP }}<span class="badge source-ldap">LDAP</span>{{ end -}}
              {{- if .FromDFS }}<span class="badge source-dfs">DFS</span>{{ end -}}
              {{- if .FromSYSVOL }}<span class="badge ad-share">SYSVOL</span>{{ end -}}
              {{- if .FromNETLOGON }}<span class="badge ad-share">NETLOGON</span>{{ end -}}
            </div>
          </div>
        </article>
        {{- end }}
      </div>
    </section>

    <section id="findings">
      <div class="section-head">
        <h2>Findings</h2>
        <span class="section-note">Grouped by category first, then ordered by severity, host, and share for faster triage.</span>
      </div>

      {{- range .CategoryGroups }}
	      <details class="group finding-group" id="cat-{{ slug .Summary.Category }}" data-category="{{ .Summary.Category }}" data-total-findings="{{ .Summary.Findings }}" open>
        <summary class="group-summary">
          <div class="group-top">
            <div class="group-title">
              <h3>{{ .Summary.Category }}</h3>
              <span class="badge {{ severityClass .Summary.HighestSeverity }}">{{ .Summary.HighestSeverity }}</span>
            </div>
            <div class="group-stats">
              <span>Visible: <span class="group-visible-count">{{ .Summary.Findings }}</span> / {{ .Summary.Findings }}</span>
              <span>Critical: {{ .Summary.Critical }}</span>
              <span>High: {{ .Summary.High }}</span>
              <span>Medium: {{ .Summary.Medium }}</span>
              <span>Low: {{ .Summary.Low }}</span>
            </div>
          </div>
          <p class="group-guidance">{{ .Summary.RemediationGuidance }}</p>
        </summary>

	        <div class="finding-list">
	          {{- range .Findings }}
	          <article class="finding-card {{ severityClass .Finding.Severity }} status-{{ .DiffStatus }}" data-search="{{ .Finding.Category }} {{ .Finding.Severity }} {{ .Finding.Confidence }} {{ .Finding.RuleID }} {{ .Finding.RuleName }} {{ .Finding.Host }} {{ .Finding.Share }} {{ .Finding.ShareType }} {{ .Finding.ShareDescription }} {{ .Finding.FilePath }} {{ .Finding.Source }} {{ .Finding.ArchivePath }} {{ .Finding.ArchiveMemberPath }} {{ .Finding.DFSNamespacePath }} {{ .Finding.DFSLinkPath }} {{ joinTags .Finding.Tags " " }} {{ .Finding.MatchReason }} {{ .Finding.RuleExplanation }} {{ .Finding.RuleRemediation }} {{ .Finding.Snippet }} {{ .Finding.Context }} {{ .Finding.ContextRedacted }} {{ .Finding.MatchedText }} {{ .Finding.MatchedTextRedacted }} {{ .Finding.PotentialAccount }} {{ .DiffStatus }} {{ joinTags .ChangedFields " " }} {{ joinList .Finding.MatchedRuleIDs " " }} {{ joinList .Finding.MatchedSignalTypes " " }} {{ joinList .Finding.ConfidenceReasons " " }}"
              data-severity="{{ .Finding.Severity }}"
              data-category="{{ .Finding.Category }}"
              data-confidence="{{ .Finding.Confidence }}"
              data-source="{{ normalizedSource .Finding.Source }}"
              data-host="{{ .Finding.Host }}"
              data-share="{{ .Finding.Share }}"
              data-signal="{{ primarySignal .Finding }}"
              data-correlated="{{ if isCorrelated .Finding }}true{{ else }}false{{ end }}"
              data-actionable="{{ if isActionable .Finding }}true{{ else }}false{{ end }}"
              data-triage="{{ .Finding.TriageClass }}">
	            <header class="finding-card-header">
	              <div class="finding-title">
	                <div class="badge-row" style="margin-top:0;">
	                  <span class="badge {{ severityClass .Finding.Severity }}">{{ .Finding.Severity }}</span>
	                  <span class="badge {{ priorityClass .Finding.Priority }}" title="{{ .Finding.PriorityReason }}">{{ priorityLabel .Finding.Priority }}</span>
	                  {{- if primarySignal .Finding }}<span class="badge {{ signalClass (primarySignal .Finding) }}">signal {{ signalLabel (primarySignal .Finding) }}</span>{{ end -}}
	                  {{- if .Finding.Confidence }}<span class="badge {{ confidenceClass .Finding.Confidence }}" title="score {{ .Finding.ConfidenceScore }}">confidence {{ .Finding.Confidence }}</span>{{ end -}}
	                  {{- if .Finding.TriageClass }}<span class="badge {{ triageClass .Finding.TriageClass }}">{{ triageLabel .Finding.TriageClass }}</span>{{ end -}}
	                  {{- if .DiffStatus }}<span class="badge {{ diffClass .DiffStatus }}">{{ diffLabel .DiffStatus }}</span>{{ end -}}
	                  {{- if .Finding.Source }}<span class="badge {{ sourceClass .Finding.Source }}">source {{ .Finding.Source }}</span>{{ end -}}
	                  {{- if .Finding.FromSYSVOL }}<span class="badge ad-share">SYSVOL</span>{{ end -}}
	                  {{- if .Finding.FromNETLOGON }}<span class="badge ad-share">NETLOGON</span>{{ end -}}
	                </div>
	                <h4>{{ .Finding.RuleName }}</h4>
	                <div class="finding-rule-id">{{ .Finding.RuleID }}</div>
	                {{- if .Finding.MatchedRuleIDs }}
	                <div class="muted" style="margin-top:8px;">Correlated rules: {{ joinList .Finding.MatchedRuleIDs ", " }}</div>
	                {{- end }}
	              </div>
	              <div class="finding-location">
	                <div class="meta-chip">
	                  <span>Host</span>
	                  <strong>{{ valueOrDash .Finding.Host }}</strong>
	                </div>
	                <div class="meta-chip">
	                  <span>Share</span>
	                  <strong>{{ valueOrDash .Finding.Share }}</strong>
	                </div>
	                <div class="meta-chip">
	                  <span>Signal Type</span>
	                  <strong>{{ valueOrDash (signalLabel (primarySignal .Finding)) }}</strong>
	                </div>
	                <div class="meta-chip">
	                  <span>Share Type</span>
	                  <strong>{{ valueOrDash .Finding.ShareType }}</strong>
	                </div>
	              </div>
	            </header>
	            <div class="finding-path" title="{{ uncPath .Finding }}">{{ uncPath .Finding }}</div>
	            <div class="finding-body">
	              <section class="finding-panel">
	                <span class="panel-title">Finding Summary</span>
	                <div class="detail-list">
	                  {{- if .Finding.ShareDescription }}
	                  <div>
	                    <strong>Share Description</strong>
	                    <div class="finding-text muted">{{ .Finding.ShareDescription }}</div>
	                  </div>
	                  {{- end }}
	                  {{- if .Finding.ArchivePath }}
	                  <div>
	                    <strong>Archive</strong>
	                    <div class="finding-text">{{ .Finding.ArchivePath }}</div>
	                  </div>
	                  <div>
	                    <strong>Archive Member</strong>
	                    <div class="finding-text">{{ .Finding.ArchiveMemberPath }}</div>
	                  </div>
	                  <div>
	                    <strong>Archive Inspection</strong>
	                    <div class="finding-text">{{ if .Finding.ArchiveLocalInspect }}local{{ else }}unknown{{ end }}</div>
	                  </div>
	                  {{- end }}
	                  <div>
	                    <strong>Evidence Tags</strong>
	                    <div class="badge-row">
	                      {{- if .Finding.Tags }}{{- range .Finding.Tags }}<span class="badge good">{{ . }}</span>{{ end }}{{ else }}<span class="muted">-</span>{{ end -}}
	                    </div>
	                  </div>
	                  {{- if .Finding.MatchedSignalTypes }}
	                  <div>
	                    <strong>Matched Signals</strong>
	                    <div class="finding-text muted">{{- range $i, $signal := .Finding.MatchedSignalTypes }}{{- if $i }}, {{ end -}}{{ signalLabel $signal }}{{- end }}</div>
	                  </div>
	                  {{- end }}
	                  {{- if .Finding.DFSNamespacePath }}
	                  <div>
	                    <strong>DFS Namespace</strong>
	                    <div class="finding-text">{{ .Finding.DFSNamespacePath }}</div>
	                  </div>
	                  {{- end }}
	                  {{- if .Finding.DFSLinkPath }}
	                  <div>
	                    <strong>DFS Link</strong>
	                    <div class="finding-text">{{ .Finding.DFSLinkPath }}</div>
	                  </div>
	                  {{- end }}
	                  {{- if eq .Finding.TriageClass "config-only" }}
	                  <div class="finding-note heuristic">Config artifact only. This item identifies a configuration-related file without actionable evidence such as real secrets, validated connection details, or crypto material.</div>
	                  {{- else if eq .Finding.TriageClass "weak-review" }}
	                  <div class="finding-note heuristic">Weak review signal. The file may warrant targeted review, but the evidence is not actionable on its own.</div>
	                  {{- else if isHeuristicHit .Finding }}
	                  <div class="finding-note heuristic">Heuristic file hit. The filename, path, or extension matched a rule. File content was not necessarily matched.</div>
	                  {{- else if eq (primarySignal .Finding) "content" }}
	                  <div class="finding-note">Content evidence was captured from the file body{{ if .Finding.LineNumber }} at line {{ .Finding.LineNumber }}{{ end }}.</div>
	                  {{- else if eq (primarySignal .Finding) "validated" }}
	                  <div class="finding-note">Validated evidence was derived from structured content or artifact parsing.</div>
	                  {{- end }}
	                </div>
	              </section>
	              <section class="finding-panel">
	                <span class="panel-title">Why It Matched</span>
	                <div class="detail-list">
	                  <div>
	                    <strong>Match Reason</strong>
	                    <div class="finding-text">{{ valueOrDash .Finding.MatchReason }}</div>
	                  </div>
	                  {{- if .Finding.Confidence }}
	                  <div>
	                    <strong>Confidence</strong>
	                    <div class="finding-text">{{ .Finding.Confidence }} confidence{{ if .Finding.ConfidenceScore }} (score {{ .Finding.ConfidenceScore }}){{ end }}</div>
	                  </div>
	                  {{- end }}
	                  {{- if .Finding.ConfidenceReasons }}
	                  <div>
	                    <strong>Confidence Reasons</strong>
	                    <ul class="confidence-reasons">
	                      {{- range .Finding.ConfidenceReasons }}
	                      <li>{{ . }}</li>
	                      {{- end }}
	                    </ul>
	                  </div>
	                  {{- end }}
	                  {{- if or .Finding.ConfidenceBreakdown.BaseScore .Finding.ConfidenceBreakdown.ValueQualityScore .Finding.ConfidenceBreakdown.ValueQualityReason }}
	                  <div>
	                    <strong>Confidence Breakdown</strong>
	                    <ul class="confidence-reasons">
	                      <li>Base score: {{ .Finding.ConfidenceBreakdown.BaseScore }}</li>
	                      <li>Content signal strength: {{ .Finding.ConfidenceBreakdown.ContentSignalStrength }}</li>
	                      <li>Heuristic signal contribution: {{ .Finding.ConfidenceBreakdown.HeuristicSignalContribution }}</li>
	                      <li>Path/context contribution: {{ .Finding.ConfidenceBreakdown.PathContextContribution }}</li>
	                      <li>Correlation contribution: {{ .Finding.ConfidenceBreakdown.CorrelationContribution }}</li>
	                      {{- if or .Finding.ConfidenceBreakdown.ValueQualityScore .Finding.ConfidenceBreakdown.ValueQualityReason }}
	                      <li>
	                        Value quality:
	                        {{- if .Finding.ConfidenceBreakdown.ValueQualityLabel }} {{ .Finding.ConfidenceBreakdown.ValueQualityLabel }}{{ end -}}
	                        {{- if .Finding.ConfidenceBreakdown.ValueQualityScore }} (score {{ .Finding.ConfidenceBreakdown.ValueQualityScore }}){{ end -}}
	                        {{- if .Finding.ConfidenceBreakdown.ValueQualityReason }}. {{ .Finding.ConfidenceBreakdown.ValueQualityReason }}{{ end -}}
	                      </li>
	                      {{- end }}
	                      {{- if .Finding.ConfidenceBreakdown.TriageAdjustment }}
	                      <li>Triage adjustment: {{ if gt .Finding.ConfidenceBreakdown.TriageAdjustment 0 }}+{{ end }}{{ .Finding.ConfidenceBreakdown.TriageAdjustment }}</li>
	                      {{- end }}
	                      {{- if .Finding.ConfidenceBreakdown.FinalScore }}
	                      <li>Final score: {{ .Finding.ConfidenceBreakdown.FinalScore }}</li>
	                      {{- end }}
	                    </ul>
	                  </div>
	                  {{- end }}
	                  {{- if .Finding.SupportingSignals }}
	                  <div>
	                    <strong>Supporting Signals</strong>
	                    <ul class="supporting-signal-list">
	                      {{- range .Finding.SupportingSignals }}
	                      <li>
	                        <span class="badge {{ signalClass .SignalType }}">{{ signalLabel .SignalType }}</span>
	                        {{- if .RuleID }} <strong>{{ .RuleID }}</strong>{{ end -}}
	                        {{- if .Reason }} {{ .Reason }}{{ end -}}
	                      </li>
	                      {{- end }}
	                    </ul>
	                  </div>
	                  {{- end }}
	                </div>
	              </section>
	              <section class="finding-panel">
	                <span class="panel-title">Visible Evidence</span>
	                <div class="kv-grid">
	                  {{- if displayMatch .Finding }}
	                  <div class="evidence-pair">
	                    <span class="evidence-label">{{ signalMatchLabel (primarySignal .Finding) }}</span>
	                    <pre class="evidence-block">{{ displayMatch .Finding }}</pre>
	                  </div>
	                  {{- end }}
	                  {{- if and .Finding.MatchedText .Finding.MatchedTextRedacted (ne .Finding.MatchedText .Finding.MatchedTextRedacted) }}
	                  <div class="evidence-pair">
	                    <span class="evidence-label">Raw Matched Text</span>
	                    <pre class="evidence-block">{{ .Finding.MatchedText }}</pre>
	                  </div>
	                  {{- end }}
	                  {{- if displayContext .Finding }}
	                  <div class="evidence-pair">
	                    <span class="evidence-label">Context / Snippet</span>
	                    <pre class="evidence-block">{{ displayContext .Finding }}</pre>
	                  </div>
	                  {{- end }}
	                  {{- if and .Finding.Context .Finding.ContextRedacted (ne .Finding.Context .Finding.ContextRedacted) }}
	                  <div class="evidence-pair">
	                    <span class="evidence-label">Raw Context</span>
	                    <pre class="evidence-block">{{ .Finding.Context }}</pre>
	                  </div>
	                  {{- end }}
	                  {{- if .Finding.LineNumber }}
	                  <div><strong>Line Number</strong><div class="finding-text">{{ .Finding.LineNumber }}</div></div>
	                  {{- end }}
	                  {{- if .Finding.PotentialAccount }}
	                  <div><strong>Potential Account Context</strong><div class="finding-text">{{ .Finding.PotentialAccount }}</div></div>
	                  {{- end }}
	                </div>
	              </section>
	              {{- if or .Finding.RuleExplanation .Finding.RuleRemediation }}
	              <section class="finding-panel">
	                <span class="panel-title">Guidance</span>
	                <div class="detail-list">
	                  {{- if .Finding.RuleExplanation }}
	                  <div>
	                    <strong>Rule Explanation</strong>
	                    <div class="finding-text">{{ .Finding.RuleExplanation }}</div>
	                  </div>
	                  {{- end }}
	                  {{- if .Finding.RuleRemediation }}
	                  <div>
	                    <strong>Remediation</strong>
	                    <div class="finding-text">{{ .Finding.RuleRemediation }}</div>
	                  </div>
	                  {{- end }}
	                </div>
	              </section>
	              {{- end }}
	            </div>
	            <details class="evidence-toggle">
	              <summary>Show Evidence</summary>
	              <div class="evidence-grid">
	                <section class="evidence-section">
	                  <strong>Matched Text</strong>
	                  {{- if displayMatch .Finding }}
	                  <pre class="evidence-block">{{ displayMatch .Finding }}</pre>
	                  {{- else }}
	                  <div class="muted">No matched text was captured.</div>
	                  {{- end }}
	                </section>
	                <section class="evidence-section">
	                  <strong>Context</strong>
	                  {{- if displayContext .Finding }}
	                  <pre class="evidence-block">{{ displayContext .Finding }}</pre>
	                  {{- else }}
	                  <div class="muted">No surrounding context was captured.</div>
	                  {{- end }}
	                  {{- if .Finding.LineNumber }}
	                  <div style="margin-top:10px;"><strong>Line Number:</strong> {{ .Finding.LineNumber }}</div>
	                  {{- end }}
	                </section>
	                <section class="evidence-section">
	                  <strong>Raw Supporting Signals</strong>
	                  {{- if .Finding.SupportingSignals }}
	                  <ul class="raw-signal-list">
	                    {{- range .Finding.SupportingSignals }}
	                    <li>
	                      <div><span class="badge {{ signalClass .SignalType }}">{{ signalLabel .SignalType }}</span>{{ if .RuleName }} <strong>{{ .RuleName }}</strong>{{ end }}</div>
	                      {{- if .RuleID }}<div class="muted">Rule ID: {{ .RuleID }}</div>{{ end -}}
	                      {{- if .Match }}<div class="finding-text">Match: {{ .Match }}</div>{{ end -}}
	                      {{- if .Confidence }}<div class="muted">Confidence: {{ .Confidence }}</div>{{ end -}}
	                      {{- if .Weight }}<div class="muted">Weight: {{ .Weight }}</div>{{ end -}}
	                      {{- if .Reason }}<div class="finding-text">{{ .Reason }}</div>{{ end -}}
	                    </li>
	                    {{- end }}
	                  </ul>
	                  {{- else }}
	                  <div class="muted">No supporting signals were recorded.</div>
	                  {{- end }}
	                </section>
	              </div>
	            </details>
	          </article>
	          {{- end }}
	        </div>
	      </details>
	      {{- end }}
	    </section>
  </main>

  <script>
    (function () {
      var input = document.getElementById("quickFilter");
      if (!input) return;
      var severityFilter = document.getElementById("severityFilter");
      var categoryFilter = document.getElementById("categoryFilter");
      var confidenceFilter = document.getElementById("confidenceFilter");
      var sourceFilter = document.getElementById("sourceFilter");
      var signalFilter = document.getElementById("signalFilter");
      var scopeFilter = document.getElementById("scopeFilter");
      var correlatedOnly = document.getElementById("correlatedOnly");
      var hideConfigOnly = document.getElementById("hideConfigOnly");
      var hideLowConfidence = document.getElementById("hideLowConfidence");
      var hideNonActionable = document.getElementById("hideNonActionable");
      var resetFilters = document.getElementById("resetFilters");
      var status = document.getElementById("filterStatus");

      function normalize(value) {
        return (value || "").trim().toLowerCase();
      }

      function applyFilter() {
        var query = input.value.trim().toLowerCase();
        var severity = normalize(severityFilter && severityFilter.value);
        var category = normalize(categoryFilter && categoryFilter.value);
        var confidence = normalize(confidenceFilter && confidenceFilter.value);
        var source = normalize(sourceFilter && sourceFilter.value);
        var signal = normalize(signalFilter && signalFilter.value);
        var scope = normalize(scopeFilter && scopeFilter.value);
        var onlyCorrelated = correlatedOnly && correlatedOnly.checked;
        var shouldHideConfigOnly = hideConfigOnly && hideConfigOnly.checked;
        var shouldHideLowConfidence = hideLowConfidence && hideLowConfidence.checked;
        var shouldHideNonActionable = hideNonActionable && hideNonActionable.checked;
        var groups = document.querySelectorAll("details.finding-group");
        var visibleGroups = 0;
        var visibleCards = 0;
        var activeFilter = query || severity || category || confidence || source || signal || scope || onlyCorrelated || shouldHideConfigOnly || shouldHideLowConfidence || shouldHideNonActionable;

        groups.forEach(function (group) {
          var cards = group.querySelectorAll(".finding-card");
          var visible = 0;

          cards.forEach(function (card) {
            var haystack = normalize(card.getAttribute("data-search"));
            var matchesText = query === "" || haystack.indexOf(query) !== -1;
            var matchesSeverity = severity === "" || normalize(card.getAttribute("data-severity")) === severity;
            var matchesCategory = category === "" || normalize(card.getAttribute("data-category")) === category;
            var matchesConfidence = confidence === "" || normalize(card.getAttribute("data-confidence")) === confidence;
            var matchesSource = source === "" || normalize(card.getAttribute("data-source")) === source;
            var matchesSignal = signal === "" || normalize(card.getAttribute("data-signal")) === signal;
            var scopeText = normalize((card.getAttribute("data-host") || "") + " " + (card.getAttribute("data-share") || ""));
            var matchesScope = scope === "" || scopeText.indexOf(scope) !== -1;
            var matchesCorrelated = !onlyCorrelated || card.getAttribute("data-correlated") === "true";
            var matchesConfigOnly = !shouldHideConfigOnly || normalize(card.getAttribute("data-triage")) !== "config-only";
            var matchesLowConfidence = !shouldHideLowConfidence || normalize(card.getAttribute("data-confidence")) === "high";
            var matchesActionable = !shouldHideNonActionable || card.getAttribute("data-actionable") === "true";
            var match = matchesText && matchesSeverity && matchesCategory && matchesConfidence && matchesSource && matchesSignal && matchesScope && matchesCorrelated && matchesConfigOnly && matchesLowConfidence && matchesActionable;

            card.classList.toggle("is-hidden", !match);
            if (match) visible++;
          });

          var visibleCount = group.querySelector(".group-visible-count");
          if (visibleCount) {
            visibleCount.textContent = String(visible);
          }

          group.classList.toggle("is-hidden", visible === 0);
          if (visible > 0) {
            visibleGroups++;
            visibleCards += visible;
          }
          if (activeFilter && visible > 0) {
            group.open = true;
          }
        });

        if (status) {
          if (!activeFilter) {
            status.textContent = "Showing all findings";
          } else {
            status.textContent = "Showing " + visibleCards + " findings across " + visibleGroups + " visible groups";
          }
        }
      }

      input.addEventListener("input", applyFilter);
      [severityFilter, categoryFilter, confidenceFilter, sourceFilter, signalFilter].forEach(function (el) {
        if (el) el.addEventListener("change", applyFilter);
      });
      if (scopeFilter) scopeFilter.addEventListener("input", applyFilter);
      [correlatedOnly, hideConfigOnly, hideLowConfidence, hideNonActionable].forEach(function (el) {
        if (el) el.addEventListener("change", applyFilter);
      });
      if (resetFilters) {
        resetFilters.addEventListener("click", function () {
          input.value = "";
          if (severityFilter) severityFilter.value = "";
          if (categoryFilter) categoryFilter.value = "";
          if (confidenceFilter) confidenceFilter.value = "";
          if (sourceFilter) sourceFilter.value = "";
          if (signalFilter) signalFilter.value = "";
          if (scopeFilter) scopeFilter.value = "";
          if (correlatedOnly) correlatedOnly.checked = false;
          if (hideConfigOnly) hideConfigOnly.checked = false;
          if (hideLowConfidence) hideLowConfidence.checked = false;
          if (hideNonActionable) hideNonActionable.checked = false;
          applyFilter();
        });
      }
    }());
  </script>
</body>
</html>
